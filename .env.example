DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"
DATABASE_URL_TEST="postgres://root:mysecretpassword@localhost:5432/local_test"

PUBLIC_URL="http://localhost:5173"

STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

MAILGUN_API_KEY="..."
MAILGUN_DOMAIN="rekisteri.tietokilta.fi"
MAILGUN_SENDER="TiK-Rekisteri <noreply@rekisteri.tietokilta.fi>"
MAILGUN_URL="https://api.eu.mailgun.net"

# adapter-node: Header to use for client IP address (Azure App Service provides X-Client-IP)
# Azure overwrites this header to prevent spoofing and excludes port numbers (unlike X-Forwarded-For)
# See: https://svelte.dev/docs/kit/adapter-node
# Azure docs: https://github.com/Azure/app-service-linux-docs/blob/master/Things_You_Should_Know/headers.md
# Reference: https://learn.microsoft.com/en-us/answers/questions/819540/documentation-on-x-client-ip-http-header
ADDRESS_HEADER=X-Client-IP

# OAuth / OpenID Connect Provider (optional - only needed if using rekisteri as OAuth provider)
# Generate RSA key pair with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# OAUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# OAUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# OAUTH_CLIENTS='[{"id":"client-id","secret":"client-secret","name":"Client Name","redirectUris":["https://example.com/callback"]}]'